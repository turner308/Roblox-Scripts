-- ── Serialization ─────────────────────────────────────────────────────────────
local function serializeFlagValue(v)
	local ty = typeof(v)
	if ty == "Color3" then
		return {
			__uw = "Color3",
			r = math.floor(v.R * 255 + 0.5),
			g = math.floor(v.G * 255 + 0.5),
			b = math.floor(v.B * 255 + 0.5),
		}
	elseif ty == "boolean" or ty == "number" or ty == "string" then
		return v
	end
	return { __uw = "tostring", v = tostring(v) }
end

local function deserializeFlagValue(v)
	if type(v) == "table" and v.__uw == "Color3" then
		return Color3.fromRGB(tonumber(v.r) or 255, tonumber(v.g) or 255, tonumber(v.b) or 255)
	elseif type(v) == "table" and v.__uw == "tostring" then
		return v.v
	end
	return v
end

local function syncOptionsContainer(container)
	for _, opt in ipairs(container.options) do
		if opt.type == "folder" then
			syncOptionsContainer(opt)
		elseif opt.RefreshFromFlags then
			pcall(opt.RefreshFromFlags, opt)
		end
	end
end

function library:SyncUIFromFlags()
	for _, w in ipairs(self.windows) do
		syncOptionsContainer(w)
	end
end

-- ── Config / persistence ──────────────────────────────────────────────────────
function library:GetAppSettingsPath()
	return (self.DataDirectory or "uwuware") .. "/app_settings.json"
end

function library:GetConfigDataPath(slot)
	slot = tostring(slot or "main"):gsub("[^%w_%-]", "_")
	return (self.DataDirectory or "uwuware") .. "/configs/" .. slot .. ".json"
end

function library:PersistAppSettings()
	if not writefile then return end
	local payload = httpService:JSONEncode({
		defaultTheme  = self.defaultTheme,
		uiToggleKey   = typeof(self.CloseKey) == "EnumItem" and self.CloseKey.Name or tostring(self.CloseKey),
	})
	pcall(writefile, self:GetAppSettingsPath(), payload)
end

local function keyNameToKeyCode(name)
	if type(name) ~= "string" then return nil end
	for _, item in ipairs(Enum.KeyCode:GetEnumItems()) do
		if item.Name == name then return item end
	end
	return nil
end

function library:SetUIToggleKey(key)
	local kc = typeof(key) == "EnumItem" and key or keyNameToKeyCode(tostring(key))
	if not kc then return end
	self.CloseKey = kc
	if self.flags then self.flags.uwuware_ui_toggle_key = kc.Name end
	self:PersistAppSettings()
end

function library:LoadPersistedAppSettings()
	if not readfile then return end
	local ok, data = pcall(readfile, self:GetAppSettingsPath())
	if not (ok and type(data) == "string" and data ~= "") then return end
	local ok2, decoded = pcall(function() return httpService:JSONDecode(data) end)
	if not (ok2 and type(decoded) == "table") then return end
	if type(decoded.defaultTheme) == "string" and Themes[decoded.defaultTheme] then
		self.defaultTheme = decoded.defaultTheme
	end
	if type(decoded.uiToggleKey) == "string" then
		local kc = keyNameToKeyCode(decoded.uiToggleKey)
		if kc then self.CloseKey = kc end
	end
end

function library:SetDefaultTheme(name)
	if not Themes[name] then return end
	self.defaultTheme = name
	if self.flags then self.flags.uwuware_startup_style = name end
	self:PersistAppSettings()
	self:SyncUIFromFlags()
end

function library:SaveConfig(slot)
	slot = tostring(slot or (self.flags and self.flags.uwuware_config_slot) or "main")
	local export = {}
	for k, v in pairs(self.flags) do
		if not (self.ConfigExcludeKeys and self.ConfigExcludeKeys[k]) then
			export[k] = serializeFlagValue(v)
		end
	end
	if not writefile then
		warn("[uwuware] writefile not available; config not saved.")
		return false
	end
	pcall(writefile, self:GetConfigDataPath(slot), httpService:JSONEncode(export))
	return true
end

function library:LoadConfig(slot)
	slot = tostring(slot or (self.flags and self.flags.uwuware_config_slot) or "main")
	if not readfile then warn("[uwuware] readfile not available.") return false end
	local path = self:GetConfigDataPath(slot)
	local ok, data = pcall(readfile, path)
	if not (ok and type(data) == "string" and data ~= "") then
		warn("[uwuware] No config file:", path) return false
	end
	local ok2, decoded = pcall(function() return httpService:JSONDecode(data) end)
	if not (ok2 and type(decoded) == "table") then
		warn("[uwuware] Invalid config JSON.") return false
	end
	for k, v in pairs(decoded) do
		self.flags[k] = deserializeFlagValue(v)
	end
	local themeApply = self.flags.uwuware_theme
	if type(themeApply) ~= "string" or not Themes[themeApply] then
		themeApply = self.flags.uwuware_startup_style
	end
	if type(themeApply) == "string" and Themes[themeApply] then
		self:SetTheme(themeApply)
	end
	if type(self.flags.uwuware_startup_style) == "string" and Themes[self.flags.uwuware_startup_style] then
		self.defaultTheme = self.flags.uwuware_startup_style
		self:PersistAppSettings()
	end
	if type(self.flags.uwuware_ui_toggle_key) == "string" then
		self:SetUIToggleKey(self.flags.uwuware_ui_toggle_key)
	end
	self:SyncUIFromFlags()
	return true
end

-- ── Fade system ───────────────────────────────────────────────────────────────
local fadePropKeys = {
	"BackgroundTransparency", "TextTransparency", "TextStrokeTransparency",
	"ImageTransparency", "GroupTransparency", "ScrollBarImageTransparency",
}

local function tryReadTranspProp(obj, key)
	local ok, v = pcall(function() return obj[key] end)
	return (ok and type(v) == "number") and math.clamp(v, 0, 1) or nil
end

local function buildFadeRows(root)
	if not root then return {} end
	local rows = {}
	local function addGuiObject(obj)
		if not obj or not obj:IsA("GuiObject") then return end
		local snap = {}
		for _, k in ipairs(fadePropKeys) do
			local v = tryReadTranspProp(obj, k)
			if v ~= nil then snap[k] = v end
		end
		if next(snap) then rows[#rows + 1] = { obj = obj, snap = snap } end
	end
	addGuiObject(root)
	for _, d in ipairs(root:GetDescendants()) do
		if d:IsA("GuiObject") then
			addGuiObject(d)
		elseif d:IsA("UIStroke") then
			local v = tryReadTranspProp(d, "Transparency")
			if v ~= nil then rows[#rows + 1] = { obj = d, snap = { Transparency = v } } end
		end
	end
	return rows
end

local function fadeQuadEase(t)
	t = math.clamp(t, 0, 1)
	return 1 - (1 - t) * (1 - t)
end

local function applyHideFadeProgress(rows, e)
	for _, row in ipairs(rows) do
		if row.obj and row.obj.Parent then
			for k, v in pairs(row.snap) do
				pcall(function() row.obj[k] = v + (1 - v) * e end)
			end
		end
	end
end

local function applyShowFadeProgress(rows, e)
	for _, row in ipairs(rows) do
		if row.obj and row.obj.Parent then
			for k, v in pairs(row.snap) do
				pcall(function() row.obj[k] = 1 - (1 - v) * e end)
			end
		end
	end
end

local function snapFadeRowsToTarget(rows)
	for _, row in ipairs(rows) do
		if row.obj and row.obj.Parent then
			for k, v in pairs(row.snap) do
				pcall(function() row.obj[k] = v end)
			end
		end
	end
end

function library:_cancelFadeMotion()
	if self._fadeConn then self._fadeConn:Disconnect(); self._fadeConn = nil end
	if self._fadeTween then self._fadeTween:Cancel(); self._fadeTween = nil end
end

function library:ShowUI()
	local dur = self.UIFadeDuration or 0.28
	if not self.fadeContainer then
		self.base.Enabled = true
		self.open, self._uiVisible = true, true
		return
	end
	self:_cancelFadeMotion()
	if self._fadeHiding then
		self._fadeHiding = false
		self.base.Enabled = true
		self.open, self._uiVisible = true, true
		if self._lastFadeSnapshot then snapFadeRowsToTarget(self._lastFadeSnapshot) end
		return
	end
	local wasOff = not self.base.Enabled
	self.base.Enabled = true
	self.open, self._uiVisible = true, true
	if not wasOff then return end

	local rows = self._lastFadeSnapshot
	if not rows or #rows == 0 then
		rows = buildFadeRows(self.fadeContainer)
		self._lastFadeSnapshot = rows
	end
	applyShowFadeProgress(rows, 0)
	local t0 = tick()
	self._fadeConn = runService.Heartbeat:Connect(function()
		local linear = (tick() - t0) / dur
		if linear >= 1 then
			if self._fadeConn then self._fadeConn:Disconnect(); self._fadeConn = nil end
			snapFadeRowsToTarget(rows)
			return
		end
		applyShowFadeProgress(rows, fadeQuadEase(linear))
	end)
end

function library:HideUI()
	local dur = self.UIFadeDuration or 0.28
	self.open, self._uiVisible = false, false
	if self.activePopup then self.activePopup:Close() end
	if not self.fadeContainer then
		self.base.Enabled = false
		return
	end
	self:_cancelFadeMotion()
	self._fadeHiding = true
	local rows = buildFadeRows(self.fadeContainer)
	self._lastFadeSnapshot = rows
	local t0 = tick()
	self._fadeConn = runService.Heartbeat:Connect(function()
		local linear = (tick() - t0) / dur
		if linear >= 1 then
			if self._fadeConn then self._fadeConn:Disconnect(); self._fadeConn = nil end
			applyHideFadeProgress(rows, 1)
			self._fadeHiding = false
			self.base.Enabled = false
			return
		end
		applyHideFadeProgress(rows, fadeQuadEase(linear))
	end)
end

function library:ToggleUI()
	if self._uiVisible then self:HideUI() else self:ShowUI() end
end

-- ── Drag system ───────────────────────────────────────────────────────────────
local dragging, dragInput, dragStart, startPos, dragObject

local blacklistedKeys = {
	Enum.KeyCode.Unknown, Enum.KeyCode.W, Enum.KeyCode.A, Enum.KeyCode.S,
	Enum.KeyCode.D, Enum.KeyCode.Slash, Enum.KeyCode.Tab,
	Enum.KeyCode.Backspace, Enum.KeyCode.Escape,
}
local whitelistedMouseInputs = {
	Enum.UserInputType.MouseButton1,
	Enum.UserInputType.MouseButton2,
	Enum.UserInputType.MouseButton3,
}

local function round(num, bracket)
	bracket = bracket or 1
	local a = math.floor(num / bracket + math.sign(num) * 0.5) * bracket
	if a < 0 then a += bracket end
	return a
end

local function keyCheck(x, list)
	for _, v in ipairs(list) do
		if v == x then return true end
	end
	return false
end

local function updateDrag(input)
	local delta = input.Position - dragStart
	local yPos = math.max(startPos.Y.Offset + delta.Y, -36)
	dragObject:TweenPosition(
		UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, yPos),
		Enum.EasingDirection.Out, Enum.EasingStyle.Quint, 0.1, true
	)
end

