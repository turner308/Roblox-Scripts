-- ── Bind ──────────────────────────────────────────────────────────────────────
local function createBind(option, parent)
	local binding = false
	local loop

	local function formatKey(key)
		return string.match(key, "Mouse")
			and string.sub(key, 1, 5) .. string.sub(key, 12, 13)
			or key
	end

	local text = formatKey(option.key)

	local main = library:Create("TextLabel", {
		LayoutOrder    = option.position,
		Size           = UDim2.new(1, 0, 0, 33),
		BackgroundTransparency = 1,
		Text           = " " .. option.text,
		TextSize       = 17,
		Font           = Enum.Font.Gotham,
		RichText       = true,
		TextColor3     = library.Colors.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent         = parent.content,
	})

	local roundImg = library:Create("ImageLabel", {
		Position    = UDim2.new(1, -6, 0, 4),
		Size        = UDim2.new(0, -textService:GetTextSize(text, 16, Enum.Font.Gotham, Vector2.new(9e9, 9e9)).X - 16, 1, -10),
		SizeConstraint = Enum.SizeConstraint.RelativeYY,
		BackgroundTransparency = 1,
		Image       = "rbxassetid://3570695787",
		ImageColor3 = library._sh.surface,
		ScaleType   = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale  = 0.02,
		Parent      = main,
	})

	local bindinput = library:Create("TextLabel", {
		Size       = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Text       = text,
		TextSize   = 16,
		RichText   = true,
		Font       = Enum.Font.Gotham,
		TextColor3 = library.Colors.Text,
		Parent     = roundImg,
	})

	local inContact = false
	local ti01 = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local ti02 = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	main.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = true
			if not binding then
				tweenService:Create(roundImg, ti01, { ImageColor3 = library._sh.surfaceHi }):Play()
			end
		end
	end)

	main.InputEnded:Connect(function(input)
		local ut = input.UserInputType
		if ut == Enum.UserInputType.MouseButton1 then
			binding = true
			bindinput.Text = "..."
			tweenService:Create(roundImg, ti02, { ImageColor3 = library.Colors.Accent }):Play()
		elseif ut == Enum.UserInputType.MouseMovement then
			inContact = false
			if not binding then
				tweenService:Create(roundImg, ti01, { ImageColor3 = library._sh.surface }):Play()
			end
		end
	end)

	inputService.InputBegan:Connect(function(input)
		if inputService:GetFocusedTextBox() then return end
		if (input.KeyCode.Name == option.key or input.UserInputType.Name == option.key) and not binding then
			if option.hold then
				loop = runService.Heartbeat:Connect(function()
					if binding then
						if loop then loop:Disconnect(); loop = nil end
						option.callback(true)
					else
						option.callback()
					end
				end)
			else
				option.callback()
			end
		elseif binding then
			local key
			pcall(function()
				if not keyCheck(input.KeyCode, blacklistedKeys) then key = input.KeyCode end
			end)
			pcall(function()
				if keyCheck(input.UserInputType, whitelistedMouseInputs) and not key then
					key = input.UserInputType
				end
			end)
			option:SetKey(key or option.key)
		end
	end)

	inputService.InputEnded:Connect(function(input)
		if input.KeyCode.Name == option.key
			or input.UserInputType.Name == option.key
			or input.UserInputType == Enum.UserInputType.MouseMovement
		then
			if loop then
				loop:Disconnect(); loop = nil
				option.callback(true)
			end
		end
	end)

	function option:SetKey(key)
		binding = false
		if loop then loop:Disconnect(); loop = nil end
		self.key = (type(key) == "string" and key) or (key and key.Name) or self.key
		library.flags[self.flag] = self.key
		bindinput.Text = formatKey(self.key)
		local s = library._sh
		tweenService:Create(roundImg, ti02, {
			ImageColor3 = inContact and s.surfaceHi or s.surface,
		}):Play()
		roundImg.Size = UDim2.new(
			0, -textService:GetTextSize(bindinput.Text, 15, Enum.Font.Gotham, Vector2.new(9e9, 9e9)).X - 16,
			1, -10
		)
		if option.applyAsCloseKey then library:SetUIToggleKey(self.key) end
	end

	function option:RefreshFromFlags()
		local k = library.flags[self.flag]
		if k ~= nil and k ~= self.key then self:SetKey(k) end
	end

	library:RegisterThemeHook(function()
		main.TextColor3     = library.Colors.Text
		bindinput.TextColor3 = library.Colors.Text
		local s = library._sh
		roundImg.ImageColor3 = binding and library.Colors.Accent
			or (inContact and s.surfaceHi or s.surface)
	end)
end

-- ── Slider ────────────────────────────────────────────────────────────────────
local function createSlider(option, parent)
	local main = library:Create("Frame", {
		LayoutOrder = option.position,
		Size        = UDim2.new(1, 0, 0, 50),
		BackgroundTransparency = 1,
		Parent      = parent.content,
	})

	local title = library:Create("TextLabel", {
		Position   = UDim2.new(0, 0, 0, 4),
		Size       = UDim2.new(1, 0, 0, 20),
		BackgroundTransparency = 1,
		Text       = " " .. option.text,
		TextSize   = 17,
		Font       = Enum.Font.Gotham,
		TextColor3 = library.Colors.Text,
		RichText   = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent     = main,
	})

	local sh = library._sh
	local slider = library:Create("ImageLabel", {
		Position    = UDim2.new(0, 10, 0, 34),
		Size        = UDim2.new(1, -20, 0, 5),
		BackgroundTransparency = 1,
		Image       = "rbxassetid://3570695787",
		ImageColor3 = sh.sliderTrack,
		ScaleType   = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale  = 0.02,
		Parent      = main,
	})

	local fill = library:Create("ImageLabel", {
		BackgroundTransparency = 1,
		Image       = "rbxassetid://3570695787",
		ImageColor3 = sh.sliderIdle,
		ScaleType   = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale  = 0.02,
		Parent      = slider,
	})

	local circle = library:Create("ImageLabel", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position    = UDim2.new((option.value - option.min) / (option.max - option.min), 0, 0.5, 0),
		SizeConstraint = Enum.SizeConstraint.RelativeYY,
		BackgroundTransparency = 1,
		Image       = "rbxassetid://3570695787",
		ImageColor3 = sh.sliderIdle,
		ScaleType   = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale  = 1,
		Parent      = slider,
	})

	local valueRound = library:Create("ImageLabel", {
		Position    = UDim2.new(1, -6, 0, 4),
		Size        = UDim2.new(0, -60, 0, 18),
		BackgroundTransparency = 1,
		Image       = "rbxassetid://3570695787",
		ImageColor3 = sh.surface,
		ScaleType   = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale  = 0.02,
		Parent      = main,
	})

	local inputvalue = library:Create("TextBox", {
		Size       = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Text       = tostring(option.value),
		TextColor3 = library.Colors.Text:Lerp(Color3.new(1, 1, 1), 0.08),
		TextSize   = 15,
		TextWrapped = true,
		Font       = Enum.Font.Gotham,
		Parent     = valueRound,
	})

	-- Initial fill position
	if option.min >= 0 then
		fill.Size = UDim2.new((option.value - option.min) / (option.max - option.min), 0, 1, 0)
	else
		fill.Position = UDim2.new((0 - option.min) / (option.max - option.min), 0, 0, 0)
		fill.Size     = UDim2.new(option.value / (option.max - option.min), 0, 1, 0)
	end

	local sliding  = false
	local inContact = false
	local ti02 = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	main.InputBegan:Connect(function(input)
		local ut = input.UserInputType
		if ut == Enum.UserInputType.MouseButton1 then
			local s = library._sh
			tweenService:Create(fill,   ti02, { ImageColor3 = library.Colors.Accent }):Play()
			tweenService:Create(circle, ti02, { Size = UDim2.new(3.5, 0, 3.5, 0), ImageColor3 = library.Colors.Accent }):Play()
			sliding = true
			option:SetValue(option.min + ((input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X) * (option.max - option.min))
		elseif ut == Enum.UserInputType.MouseMovement then
			inContact = true
			if not sliding then
				tweenService:Create(fill,   ti02, { ImageColor3 = library.Colors.Outline }):Play()
				tweenService:Create(circle, ti02, { Size = UDim2.new(2.8, 0, 2.8, 0), ImageColor3 = library.Colors.Outline }):Play()
			end
		end
	end)

	inputService.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement and sliding then
			option:SetValue(option.min + ((input.Position.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X) * (option.max - option.min))
		end
	end)

	main.InputEnded:Connect(function(input)
		local ut = input.UserInputType
		if ut == Enum.UserInputType.MouseButton1 then
			sliding = false
			local s = library._sh
			if inContact then
				tweenService:Create(fill,   ti02, { ImageColor3 = library.Colors.Outline }):Play()
				tweenService:Create(circle, ti02, { Size = UDim2.new(2.8, 0, 2.8, 0), ImageColor3 = library.Colors.Outline }):Play()
			else
				tweenService:Create(fill,   ti02, { ImageColor3 = s.sliderIdle }):Play()
				tweenService:Create(circle, ti02, { Size = UDim2.new(0, 0, 0, 0), ImageColor3 = s.sliderIdle }):Play()
			end
		elseif ut == Enum.UserInputType.MouseMovement then
			inContact = false
			inputvalue:ReleaseFocus()
			if not sliding then
				local s = library._sh
				tweenService:Create(fill,   ti02, { ImageColor3 = s.sliderIdle }):Play()
				tweenService:Create(circle, ti02, { Size = UDim2.new(0, 0, 0, 0), ImageColor3 = s.sliderIdle }):Play()
			end
		end
	end)

	inputvalue.FocusLost:Connect(function()
		tweenService:Create(circle, ti02, { Size = UDim2.new(0, 0, 0, 0), ImageColor3 = library._sh.sliderIdle }):Play()
		option:SetValue(tonumber(inputvalue.Text) or option.value)
	end)

	function option:SetValue(value)
		value = math.clamp(round(value, self.float), self.min, self.max)
		local t = (value - self.min) / (self.max - self.min)
		circle:TweenPosition(UDim2.new(t, 0, 0.5, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
		if self.min >= 0 then
			fill:TweenSize(UDim2.new(t, 0, 1, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
		else
			fill:TweenPosition(UDim2.new((0 - self.min) / (self.max - self.min), 0, 0, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
			fill:TweenSize(UDim2.new(value / (self.max - self.min), 0, 1, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
		end
		library.flags[self.flag] = value
		self.value = value
		inputvalue.Text = tostring(value)
		self.callback(value)
	end

	function option:RefreshFromFlags()
		local v = library.flags[self.flag]
		if typeof(v) == "number" then self:SetValue(v) end
	end

	library:RegisterThemeHook(function()
		title.TextColor3     = library.Colors.Text
		inputvalue.TextColor3 = library.Colors.Text:Lerp(Color3.new(1, 1, 1), 0.08)
		local s = library._sh
		slider.ImageColor3   = s.sliderTrack
		valueRound.ImageColor3 = s.surface
		if not sliding then
			fill.ImageColor3   = inContact and library.Colors.Outline or s.sliderIdle
			circle.ImageColor3 = inContact and library.Colors.Outline or s.sliderIdle
		end
	end)
end

-- ── List ──────────────────────────────────────────────────────────────────────
local function createList(option, parent)
	local valueCount = 0
	option._themeRows = option._themeRows or {}

	local main = library:Create("Frame", {
		LayoutOrder = option.position,
		Size        = UDim2.new(1, 0, 0, 52),
		BackgroundTransparency = 1,
		Parent      = parent.content,
	})

	local sh = library._sh
	local roundImg = library:Create("ImageLabel", {
		Position    = UDim2.new(0, 6, 0, 4),
		Size        = UDim2.new(1, -12, 1, -10),
		BackgroundTransparency = 1,
		Image       = "rbxassetid://3570695787",
		ImageColor3 = sh.surface,
		ScaleType   = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale  = 0.02,
		Parent      = main,
	})

	local titleLbl = library:Create("TextLabel", {
		Position   = UDim2.new(0, 12, 0, 8),
		Size       = UDim2.new(1, -24, 0, 14),
		BackgroundTransparency = 1,
		Text       = option.text,
		TextSize   = 14,
		Font       = Enum.Font.GothamBold,
		TextColor3 = sh.mutedText,
		RichText   = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent     = main,
	})

	local listvalue = library:Create("TextLabel", {
		Position   = UDim2.new(0, 12, 0, 20),
		Size       = UDim2.new(1, -24, 0, 24),
		BackgroundTransparency = 1,
		Text       = option.value,
		TextSize   = 18,
		RichText   = true,
		Font       = Enum.Font.Gotham,
		TextColor3 = library.Colors.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent     = main,
	})

	library:Create("ImageLabel", {
		Position   = UDim2.new(1, -16, 0, 16),
		Size       = UDim2.new(-1, 32, 1, -32),
		SizeConstraint = Enum.SizeConstraint.RelativeYY,
		Rotation   = 90,
		BackgroundTransparency = 1,
		Image      = "rbxassetid://4918373417",
		ImageColor3 = sh.mutedText,
		ScaleType  = Enum.ScaleType.Fit,
		Parent     = roundImg,
	})

	option.mainHolder = library:Create("ImageButton", {
		ZIndex     = 3,
		Size       = UDim2.new(0, 240, 0, 52),
		BackgroundTransparency = 1,
		Image      = "rbxassetid://3570695787",
		ImageTransparency = 1,
		ImageColor3 = sh.listDrop,
		ScaleType  = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Visible    = false,
		Parent     = library.fadeContainer or library.base,
	})

	local content = library:Create("ScrollingFrame", {
		ZIndex     = 3,
		Size       = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarImageColor3 = Color3.new(0, 0, 0),
		ScrollBarThickness = 0,
		ScrollingDirection = Enum.ScrollingDirection.Y,
		Parent     = option.mainHolder,
	})

	library:Create("UIPadding", { PaddingTop = UDim.new(0, 6), Parent = content })

	local layout = library:Create("UIListLayout", { Parent = content })

	layout.Changed:Connect(function()
		option.mainHolder.Size = UDim2.new(0, 240, 0, (valueCount > 4 and 4 * 40 or layout.AbsoluteContentSize.Y) + 12)
		content.CanvasSize    = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 12)
	end)

	local inContact = false
	local ti01 = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local ti03 = TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

	roundImg.InputBegan:Connect(function(input)
		local ut = input.UserInputType
		if ut == Enum.UserInputType.MouseButton1 then
			if library.activePopup then library.activePopup:Close() end
			local pos = main.AbsolutePosition
			option.mainHolder.Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 10)
			option.open = true
			option.mainHolder.Visible = true
			library.activePopup = option
			content.ScrollBarThickness = 6
			tweenService:Create(option.mainHolder, ti03, {
				ImageTransparency = 0,
				Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 4),
			}):Play()
			tweenService:Create(option.mainHolder,
				TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, false, 0.1),
				{ Position = UDim2.new(0, pos.X - 5, 0, pos.Y + 1) }
			):Play()
			for _, label in ipairs(content:GetChildren()) do
				if label:IsA("TextLabel") then
					tweenService:Create(label,
						TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
						{ BackgroundTransparency = 0, TextTransparency = 0 }
					):Play()
				end
			end
		elseif ut == Enum.UserInputType.MouseMovement then
			inContact = true
			if not option.open then
				tweenService:Create(roundImg, ti01, { ImageColor3 = library._sh.surfaceHi }):Play()
			end
		end
	end)

	roundImg.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = false
			if not option.open then
				tweenService:Create(roundImg, ti01, { ImageColor3 = library._sh.surface }):Play()
			end
		end
	end)

	function option:AddValue(value)
		valueCount += 1
		local s = library._sh
		local label = library:Create("TextLabel", {
			ZIndex     = 3,
			Size       = UDim2.new(1, 0, 0, 40),
			BackgroundColor3 = s.listRow,
			BorderSizePixel = 0,
			Text       = "    " .. value,
			TextSize   = 14,
			TextTransparency = self.open and 0 or 1,
			Font       = Enum.Font.Gotham,
			RichText   = true,
			TextColor3 = library.Colors.Text,
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent     = content,
		})
		table.insert(option._themeRows, label)

		local lContact, lClicking = false, false
		local lti01 = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		local lti02 = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

		label.InputBegan:Connect(function(input)
			local ut = input.UserInputType
			if ut == Enum.UserInputType.MouseButton1 then
				lClicking = true
				tweenService:Create(label, lti02, { BackgroundColor3 = library.Colors.Topbar }):Play()
				self:SetValue(value)
			elseif ut == Enum.UserInputType.MouseMovement then
				lContact = true
				if not lClicking then
					tweenService:Create(label, lti01, { BackgroundColor3 = library._sh.listRowHi }):Play()
				end
			end
		end)

		label.InputEnded:Connect(function(input)
			local ut = input.UserInputType
			if ut == Enum.UserInputType.MouseButton1 then
				lClicking = false
				tweenService:Create(label, lti02, {
					BackgroundColor3 = lContact and library._sh.listRowHi or library._sh.listRow,
				}):Play()
			elseif ut == Enum.UserInputType.MouseMovement then
				lContact = false
				if not lClicking then
					tweenService:Create(label, lti01, { BackgroundColor3 = library._sh.listRow }):Play()
				end
			end
		end)
	end

	if not table.find(option.values, option.value) then
		option:AddValue(option.value)
	end
	for _, value in ipairs(option.values) do
		option:AddValue(tostring(value))
	end

	function option:RemoveValue(value)
		for _, label in ipairs(content:GetChildren()) do
			if label:IsA("TextLabel") and label.Text == "    " .. value then
				for i, row in ipairs(option._themeRows) do
					if row == label then table.remove(option._themeRows, i); break end
				end
				label:Destroy()
				valueCount -= 1
				break
			end
		end
		if self.value == value then self:SetValue("") end
	end

	function option:SetValue(value, skipCallback)
		library.flags[self.flag] = tostring(value)
		self.value = tostring(value)
		listvalue.Text = self.value
		if not skipCallback then self.callback(value) end
	end

	function option:RefreshFromFlags()
		local v = library.flags[self.flag]
		self:SetValue(tostring(v ~= nil and v or self.value), true)
	end

	function option:Close()
		library.activePopup = nil
		self.open = false
		content.ScrollBarThickness = 0
		local pos = main.AbsolutePosition
		local s   = library._sh
		tweenService:Create(roundImg, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			ImageColor3 = inContact and s.surfaceHi or s.surface,
		}):Play()
		tweenService:Create(self.mainHolder, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			ImageTransparency = 1,
			Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 10),
		}):Play()
		for _, label in ipairs(content:GetChildren()) do
			if label:IsA("TextLabel") then
				tweenService:Create(label, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					BackgroundTransparency = 1, TextTransparency = 1,
				}):Play()
			end
		end
		task.delay(0.3, function()
			if not self.open then self.mainHolder.Visible = false end
		end)
	end

	library:RegisterThemeHook(function()
		local s = library._sh
		roundImg.ImageColor3       = (option.open or inContact) and s.surfaceHi or s.surface
		titleLbl.TextColor3        = s.mutedText
		listvalue.TextColor3       = library.Colors.Text
		option.mainHolder.ImageColor3 = s.listDrop
		for _, row in ipairs(option._themeRows) do
			if row.Parent then
				row.BackgroundColor3 = s.listRow
				row.TextColor3       = library.Colors.Text
			end
		end
	end)

	return option
end

