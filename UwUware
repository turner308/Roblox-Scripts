		BackgroundTransparency = 1,
		Text       = option.text,
		TextSize   = 14,
		Font       = Enum.Font.GothamBold,
		TextColor3 = library.Colors.Outline,
		RichText   = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent     = main,
	})

	local inputvalue = library:Create("TextBox", {
		Position   = UDim2.new(0, 12, 0, 20),
		Size       = UDim2.new(1, -24, 0, 24),
		BackgroundTransparency = 1,
		Text       = option.value,
		TextSize   = 18,
		Font       = Enum.Font.Gotham,
		TextColor3 = library.Colors.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true,
		Parent     = main,
	})

	local inContact = false
	local focused   = false
	local ti01 = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local ti02 = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	main.InputBegan:Connect(function(input)
		local ut = input.UserInputType
		if ut == Enum.UserInputType.MouseButton1 then
			if not focused then inputvalue:CaptureFocus() end
		elseif ut == Enum.UserInputType.MouseMovement then
			inContact = true
			if not focused then
				tweenService:Create(outline, ti01, { ImageColor3 = library.Colors.Outline }):Play()
			end
		end
	end)

	main.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = false
			if not focused then
				tweenService:Create(outline, ti01, { ImageColor3 = library._sh.sliderIdle }):Play()
			end
		end
	end)

	inputvalue.Focused:Connect(function()
		focused = true
		tweenService:Create(outline, ti02, { ImageColor3 = library.Colors.Accent }):Play()
	end)

	inputvalue.FocusLost:Connect(function(enter)
		focused = false
		tweenService:Create(outline, ti02, { ImageColor3 = library._sh.sliderIdle }):Play()
		option:SetValue(inputvalue.Text, enter)
	end)

	function option:SetValue(value, enter)
		library.flags[self.flag] = tostring(value)
		self.value = tostring(value)
		inputvalue.Text = self.value
		self.callback(value, enter)
	end

	function option:RefreshFromFlags()
		self:SetValue(tostring(library.flags[self.flag] ~= nil and library.flags[self.flag] or self.value), nil)
	end

	library:RegisterThemeHook(function()
		titleLbl.TextColor3    = library.Colors.Outline
		inputvalue.TextColor3  = library.Colors.Text
		local s = library._sh
		outline.ImageColor3 = focused and library.Colors.Accent
			or (inContact and library.Colors.Outline or s.sliderIdle)
	end)
end

-- ── Color picker window ───────────────────────────────────────────────────────
local function createColorPickerWindow(option)
	local sh = library._sh
	option.mainHolder = library:Create("ImageButton", {
		ZIndex     = 3,
		Size       = UDim2.new(0, 240, 0, 180),
		BackgroundTransparency = 1,
		Image      = "rbxassetid://3570695787",
		ImageTransparency = 1,
		ImageColor3 = sh.listDrop,
		ScaleType  = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent     = library.fadeContainer or library.base,
	})

	local hue, sat, val = Color3.toHSV(option.color)
	hue = hue == 0 and 1 or hue
	sat = sat + 0.005
	val = val - 0.005

	local editinghue   = false
	local editingsatval = false
	local currentColor = option.color
	local previousColors = { option.color }
	local originalColor  = option.color
	local rainbowEnabled = false
	local rainbowLoop

	function option:updateVisuals(color)
		currentColor = color
		self.visualize2.ImageColor3 = color
		hue, sat, val = Color3.toHSV(color)
		hue = hue == 0 and 1 or hue
		self.satval.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
		self.hueSlider.Position   = UDim2.new(1 - hue, 0, 0, 0)
		self.satvalSlider.Position = UDim2.new(sat, 0, 1 - val, 0)
	end

	-- Hue bar
	option.hue = library:Create("ImageLabel", {
		ZIndex     = 3,
		AnchorPoint = Vector2.new(0, 1),
		Position   = UDim2.new(0, 8, 1, -8),
		Size       = UDim2.new(1, -100, 0, 22),
		BackgroundTransparency = 1,
		Image      = "rbxassetid://3570695787",
		ImageTransparency = 1,
		ScaleType  = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent     = option.mainHolder,
	})

	library:Create("UIGradient", {
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0,     Color3.fromRGB(255,   0,   0)),
			ColorSequenceKeypoint.new(0.157, Color3.fromRGB(255,   0, 255)),
			ColorSequenceKeypoint.new(0.323, Color3.fromRGB(0,     0, 255)),
			ColorSequenceKeypoint.new(0.488, Color3.fromRGB(0,   255, 255)),
			ColorSequenceKeypoint.new(0.66,  Color3.fromRGB(0,   255,   0)),
			ColorSequenceKeypoint.new(0.817, Color3.fromRGB(255, 255,   0)),
			ColorSequenceKeypoint.new(1,     Color3.fromRGB(255,   0,   0)),
		}),
		Parent = option.hue,
	})

	option.hueSlider = library:Create("Frame", {
		ZIndex     = 3,
		Position   = UDim2.new(1 - hue, 0, 0, 0),
		Size       = UDim2.new(0, 2, 1, 0),
		BackgroundTransparency = 1,
		BackgroundColor3 = Color3.fromRGB(30, 30, 30),
		BorderColor3 = Color3.fromRGB(255, 255, 255),
		Parent     = option.hue,
	})

	local function clampHue(x)
		return math.clamp((x - option.hue.AbsolutePosition.X) / option.hue.AbsoluteSize.X, 0, 0.995)
	end

	option.hue.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			editinghue = true
			option:updateVisuals(Color3.fromHSV(1 - clampHue(input.Position.X), sat, val))
		end
	end)

	inputService.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			if editinghue then
				option:updateVisuals(Color3.fromHSV(1 - clampHue(input.Position.X), sat, val))
			end
		end
	end)

	option.hue.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then editinghue = false end
	end)

	-- Saturation/value square
	option.satval = library:Create("ImageLabel", {
		ZIndex     = 3,
		Position   = UDim2.new(0, 8, 0, 8),
		Size       = UDim2.new(1, -100, 1, -42),
		BackgroundTransparency = 1,
		BackgroundColor3 = Color3.fromHSV(hue, 1, 1),
		BorderSizePixel = 0,
		Image      = "rbxassetid://4155801252",
		ImageTransparency = 1,
		ClipsDescendants = true,
		Parent     = option.mainHolder,
	})

	option.satvalSlider = library:Create("Frame", {
		ZIndex     = 3,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position   = UDim2.new(sat, 0, 1 - val, 0),
		Size       = UDim2.new(0, 4, 0, 4),
		Rotation   = 45,
		BackgroundTransparency = 1,
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		Parent     = option.satval,
	})

	local function clampSatVal(input)
		local sx = math.clamp((input.Position.X - option.satval.AbsolutePosition.X) / option.satval.AbsoluteSize.X, 0.005, 1)
		local sy = math.clamp((input.Position.Y - option.satval.AbsolutePosition.Y) / option.satval.AbsoluteSize.Y, 0, 0.995)
		return sx, sy
	end

	option.satval.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			editingsatval = true
			local x, y = clampSatVal(input)
			option:updateVisuals(Color3.fromHSV(hue, x, 1 - y))
		end
	end)

	inputService.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement and editingsatval then
			local x, y = clampSatVal(input)
			option:updateVisuals(Color3.fromHSV(hue, x, 1 - y))
		end
	end)

	option.satval.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then editingsatval = false end
	end)

	-- Color preview
	option.visualize2 = library:Create("ImageLabel", {
		ZIndex     = 3,
		Position   = UDim2.new(1, -8, 0, 8),
		Size       = UDim2.new(0, -80, 0, 80),
		BackgroundTransparency = 1,
		Image      = "rbxassetid://3570695787",
		ImageColor3 = currentColor,
		ScaleType  = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent     = option.mainHolder,
	})

	-- Chrome buttons helper
	local function makeChrome(yPos, labelText)
		local btn = library:Create("ImageLabel", {
			ZIndex     = 3,
			Position   = UDim2.new(1, -8, 0, yPos),
			Size       = UDim2.new(0, -80, 0, 18),
			BackgroundTransparency = 1,
			Image      = "rbxassetid://3570695787",
			ImageTransparency = 1,
			ImageColor3 = library._sh.chromeButton,
			ScaleType  = Enum.ScaleType.Slice,
			SliceCenter = Rect.new(100, 100, 100, 100),
			SliceScale = 0.02,
			Parent     = option.mainHolder,
		})
		local lbl = library:Create("TextLabel", {
			ZIndex     = 3,
			Size       = UDim2.new(1, 0, 1, 0),
			BackgroundTransparency = 1,
			Text       = labelText,
			TextTransparency = 1,
			Font       = Enum.Font.Code,
			TextSize   = 15,
			TextColor3 = library.Colors.Text,
			RichText   = true,
			Parent     = btn,
		})
		local ti02 = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		btn.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement and not dragging then
				tweenService:Create(btn, ti02, { ImageColor3 = library.Colors.Topbar }):Play()
			end
		end)
		btn.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement and not dragging then
				tweenService:Create(btn, ti02, { ImageColor3 = library._sh.chromeButton }):Play()
			end
		end)
		return btn, lbl
	end

	option.resetColor, option.resetText = makeChrome(92, "Reset")
	option.undoColor,  option.undoText  = makeChrome(112, "Undo")
	option.setColor,   option.setText   = makeChrome(132, "Set")
	option.rainbow,    option.rainbowText = makeChrome(152, "Rainbow")

	option.resetColor.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 and not rainbowEnabled then
			previousColors = { originalColor }
			option:SetColor(originalColor)
		end
	end)

	option.undoColor.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 and not rainbowEnabled then
			local num = #previousColors == 1 and 0 or 1
			option:SetColor(previousColors[#previousColors - num])
			if #previousColors ~= 1 then table.remove(previousColors) end
		end
	end)

	option.setColor.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 and not rainbowEnabled then
			table.insert(previousColors, currentColor)
			option:SetColor(currentColor)
		end
	end)

	option.rainbow.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			rainbowEnabled = not rainbowEnabled
			if rainbowEnabled then
				rainbowLoop = runService.Heartbeat:Connect(function()
					option:SetColor(chromaColor)
					option.rainbowText.TextColor3 = chromaColor
				end)
			else
				if rainbowLoop then rainbowLoop:Disconnect(); rainbowLoop = nil end
				option:SetColor(previousColors[#previousColors])
				option.rainbowText.TextColor3 = library.Colors.Text
			end
		end
	end)

	library:RegisterThemeHook(function()
		if not option.mainHolder then return end
		local s = library._sh
		option.mainHolder.ImageColor3  = s.listDrop
		option.resetColor.ImageColor3  = s.chromeButton
		option.undoColor.ImageColor3   = s.chromeButton
		option.setColor.ImageColor3    = s.chromeButton
		option.rainbow.ImageColor3     = s.chromeButton
		option.resetText.TextColor3    = library.Colors.Text
		option.undoText.TextColor3     = library.Colors.Text
		option.setText.TextColor3      = library.Colors.Text
		if not rainbowEnabled then
			option.rainbowText.TextColor3 = library.Colors.Text
		end
	end)

	return option
end

-- ── Color (inline) ────────────────────────────────────────────────────────────
local function createColor(option, parent)
	option.main = library:Create("TextLabel", {
		LayoutOrder = option.position,
		Size        = UDim2.new(1, 0, 0, 31),
		BackgroundTransparency = 1,
		Text        = " " .. option.text,
		TextSize    = 17,
		Font        = Enum.Font.Gotham,
		TextColor3  = library.Colors.Text,
		RichText    = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent      = parent.content,
	})

	local colorBoxOutline = library:Create("ImageLabel", {
		Position    = UDim2.new(1, -6, 0, 4),
		Size        = UDim2.new(-1, 10, 1, -10),
		SizeConstraint = Enum.SizeConstraint.RelativeYY,
		BackgroundTransparency = 1,
		Image       = "rbxassetid://3570695787",
		ImageColor3 = library.Colors.Outline,
		ScaleType   = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale  = 0.02,
		Parent      = option.main,
	})

	option.visualize = library:Create("ImageLabel", {
		Position    = UDim2.new(0, 2, 0, 2),
		Size        = UDim2.new(1, -4, 1, -4),
		BackgroundTransparency = 1,
		Image       = "rbxassetid://3570695787",
		ImageColor3 = option.color,
		ScaleType   = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale  = 0.02,
		Parent      = colorBoxOutline,
	})

	local inContact = false
	local ti01 = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local ti03q = TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
	local ti04  = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, false, 0.1)

	option.main.InputBegan:Connect(function(input)
		local ut = input.UserInputType
		if ut == Enum.UserInputType.MouseButton1 then
			if not option.mainHolder then createColorPickerWindow(option) end
			if library.activePopup then library.activePopup:Close() end
			local pos = option.main.AbsolutePosition
			option.mainHolder.Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 10)
			option.open = true
			option.mainHolder.Visible = true
			library.activePopup = option
			tweenService:Create(option.mainHolder, ti03q, {
				ImageTransparency = 0,
				Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 4),
			}):Play()
			tweenService:Create(option.mainHolder, ti04, {
				Position = UDim2.new(0, pos.X - 5, 0, pos.Y + 1),
			}):Play()
			tweenService:Create(option.satval, ti03q, { BackgroundTransparency = 0 }):Play()
			for _, obj in ipairs(option.mainHolder:GetDescendants()) do
				if obj:IsA("TextLabel") then
					tweenService:Create(obj, ti03q, { TextTransparency = 0 }):Play()
				elseif obj:IsA("ImageLabel") then
					tweenService:Create(obj, ti03q, { ImageTransparency = 0 }):Play()
				elseif obj:IsA("Frame") then
					tweenService:Create(obj, ti03q, { BackgroundTransparency = 0 }):Play()
				end
			end
		elseif ut == Enum.UserInputType.MouseMovement then
			inContact = true
			if not option.open then
				tweenService:Create(colorBoxOutline, ti01, { ImageColor3 = library._sh.tickHoverInactive }):Play()
			end
		end
	end)

	option.main.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = false  -- (was incorrectly `true` in original)
			if not option.open then
				tweenService:Create(colorBoxOutline, ti01, { ImageColor3 = library.Colors.Outline }):Play()
			end
		end
	end)

	function option:SetColor(newColor)
		if self.mainHolder then self:updateVisuals(newColor) end
		self.visualize.ImageColor3 = newColor
		library.flags[self.flag]   = newColor
		self.color = newColor
		self.callback(newColor)
	end

	function option:RefreshFromFlags()
		local c = library.flags[self.flag]
		if typeof(c) == "Color3" then self:SetColor(c) end
	end

	function option:Close()
		library.activePopup = nil
		self.open = false
		local pos = self.main.AbsolutePosition
		local ti03b = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		tweenService:Create(self.mainHolder, ti03b, {
			ImageTransparency = 1,
			Position = UDim2.new(0, pos.X - 5, 0, pos.Y - 10),
		}):Play()
		tweenService:Create(self.satval, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			BackgroundTransparency = 1,
		}):Play()
		for _, obj in ipairs(self.mainHolder:GetDescendants()) do
			if obj:IsA("TextLabel") then
				tweenService:Create(obj, ti03b, { TextTransparency = 1 }):Play()
			elseif obj:IsA("ImageLabel") then
				tweenService:Create(obj, ti03b, { ImageTransparency = 1 }):Play()
			elseif obj:IsA("Frame") then
				tweenService:Create(obj, ti03b, { BackgroundTransparency = 1 }):Play()
			end
		end
		task.delay(0.3, function()
			if not self.open then self.mainHolder.Visible = false end
		end)
	end

	library:RegisterThemeHook(function()
		option.main.TextColor3    = library.Colors.Text
		colorBoxOutline.ImageColor3 = inContact and library._sh.tickHoverInactive or library.Colors.Outline
	end)
end

-- ── Option loader / builder ───────────────────────────────────────────────────
local function loadOptions(option)
	for _, newOption in ipairs(option.options) do
		if     newOption.type == "label"  then createLabel(newOption, option)
		elseif newOption.type == "toggle" then createToggle(newOption, option)
		elseif newOption.type == "button" then
			if newOption.splitRight then
				createSplitButton(newOption, newOption.splitRight, option)
			else
				createButton(newOption, option)
			end
		elseif newOption.type == "list"   then createList(newOption, option)
		elseif newOption.type == "box"    then createBox(newOption, option)
		elseif newOption.type == "bind"   then createBind(newOption, option)
		elseif newOption.type == "slider" then createSlider(newOption, option)
		elseif newOption.type == "color"  then createColor(newOption, option)
		elseif newOption.type == "folder" then newOption:init()
		end
	end
end

local function getFunctions(parent)
	function parent:AddLabel(option)
		option = type(option) == "table" and option or {}
		option.text, option.type, option.position = tostring(option.text), "label", #self.options
		table.insert(self.options, option)
		return option
	end

	function parent:AddToggle(option)
		option = type(option) == "table" and option or {}
		option.text     = tostring(option.text)
		option.state    = typeof(option.state) == "boolean" and option.state or false
		option.callback = type(option.callback) == "function" and option.callback or function() end
		option.type, option.position = "toggle", #self.options
		option.flag = option.flag or option.text
		library.flags[option.flag] = option.state
		table.insert(self.options, option)
		return option
	end

	function parent:AddButton(option)
		option = type(option) == "table" and option or {}
		option.text     = tostring(option.text)
		option.callback = type(option.callback) == "function" and option.callback or function() end
		option.type, option.position = "button", #self.options
		option.flag = option.flag or option.text
		table.insert(self.options, option)

		function option:AddButton(rightOption)
			assert(not self.splitRight, "This row already has a split (right) button")
			rightOption = type(rightOption) == "table" and rightOption or {}
			rightOption.text     = tostring(rightOption.text)
			rightOption.callback = type(rightOption.callback) == "function" and rightOption.callback or function() end
			rightOption.type = "button"
			rightOption.flag = rightOption.flag or rightOption.text
			self.splitRight  = rightOption
			return rightOption
		end

		return option
	end

	function parent:AddBind(option)
		option = type(option) == "table" and option or {}
		option.text     = tostring(option.text)
		option.key      = (option.key and (type(option.key) == "string" and option.key or option.key.Name)) or "F"
		option.hold     = typeof(option.hold) == "boolean" and option.hold or false
		option.callback = type(option.callback) == "function" and option.callback or function() end
		option.type, option.position = "bind", #self.options
		option.flag = option.flag or option.text
		library.flags[option.flag] = option.key
		table.insert(self.options, option)
		return option
	end

	function parent:AddSlider(option)
		option = type(option) == "table" and option or {}
		option.text     = tostring(option.text)
		option.min      = typeof(option.min) == "number" and option.min or 0
		option.max      = typeof(option.max) == "number" and option.max or 0
		option.dual     = typeof(option.dual) == "boolean" and option.dual or false
		option.value    = math.clamp(typeof(option.value) == "number" and option.value or option.min, option.min, option.max)
		option.value2   = typeof(option.value2) == "number" and option.value2 or option.max
		option.callback = type(option.callback) == "function" and option.callback or function() end
		option.float    = typeof(option.float) == "number" and option.float or 1
		option.type, option.position = "slider", #self.options
		option.flag = option.flag or option.text
		library.flags[option.flag] = option.value
		table.insert(self.options, option)
		return option
	end

	function parent:AddList(option)
		option = type(option) == "table" and option or {}
		option.text     = tostring(option.text)
		option.values   = type(option.values) == "table" and option.values or {}
		option.value    = tostring(option.value or option.values[1] or "")
		option.callback = type(option.callback) == "function" and option.callback or function() end
		option.open     = false
		option.type, option.position = "list", #self.options
		option.flag = option.flag or option.text
		library.flags[option.flag] = option.value
		table.insert(self.options, option)
		return option
	end

	function parent:AddBox(option)
		option = type(option) == "table" and option or {}
		option.text     = tostring(option.text)
		option.value    = tostring(option.value or "")
		option.callback = type(option.callback) == "function" and option.callback or function() end
		option.type, option.position = "box", #self.options
		option.flag = option.flag or option.text
		library.flags[option.flag] = option.value
		table.insert(self.options, option)
		return option
	end

	function parent:AddColor(option)
		option = type(option) == "table" and option or {}
		option.text     = tostring(option.text)
		if type(option.color) == "table" then
			option.color = Color3.new(tonumber(option.color[1]) or 0, tonumber(option.color[2]) or 0, tonumber(option.color[3]) or 0)
		else
			option.color = typeof(option.color) == "Color3" and option.color or Color3.new(1, 1, 1)
		end
		option.callback = type(option.callback) == "function" and option.callback or function() end
		option.open     = false
		option.type, option.position = "color", #self.options
		option.flag = option.flag or option.text
		library.flags[option.flag] = option.color
		table.insert(self.options, option)
		return option
	end

	function parent:AddFolder(title)
		local option = {
			title    = tostring(title),
			options  = {},
			open     = false,
			type     = "folder",
			position = #self.options,
		}
		table.insert(self.options, option)
		getFunctions(option)

		function option:init()
			createOptionHolder(self.title, parent.content, self, true)
			loadOptions(self)
		end

		return option
	end
end

-- ── Window factory ────────────────────────────────────────────────────────────
function library:CreateWindow(title)
	local window = {
		title    = tostring(title),
		options  = {},
		open     = true,
		canInit  = true,
		init     = false,
		position = #self.windows,
	}
	getFunctions(window)
	table.insert(self.windows, window)
	return window
end

-- ── Init ──────────────────────────────────────────────────────────────────────
function library:Init()
	self:LoadPersistedAppSettings()
	if self.LoadPersistedSettingsOnInit ~= false and Themes[self.defaultTheme] then
		self:SetTheme(self.defaultTheme)
	end

	self.base = self.base or self:Create("ScreenGui", {
		Name           = "uwuware_ScreenGui",
		ResetOnSpawn   = false,
		DisplayOrder   = 9999,
		IgnoreGuiInset = true,
	})

	self.alive = true
	self.base.Destroying:Connect(function() self.alive = false end)

	-- ── GUI protection (hardened) ──────────────────────────────────────────
	-- 1) Try real protect_gui / gethui / get_hidden_gui
	-- 2) Ensure no other local script can re-parent or destroy the ScreenGui
	_protectGui(self.base)
	-- Explicit CoreGui parent re-enforcement after protect attempt
	pcall(function() self.base.Parent = game:GetService("CoreGui") end)

	-- 3) Guard against the ScreenGui being unexpectedly reparented out of
	--    protected storage (e.g. a rogue LocalScript ancestry change).
	self.base.AncestryChanged:Connect(function(_, newParent)
		if newParent ~= game:GetService("CoreGui") then
			task.defer(function() _protectGui(self.base) end)
		end
	end)

	-- Fade container
	self.fadeContainer = self.fadeContainer or self:Create("Frame", {
		Name               = "UwuwareFadeRoot",
		Parent             = self.base,
		Size               = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		BorderSizePixel    = 0,
		ClipsDescendants   = false,
	})

	-- Toggle key
	inputService.InputBegan:Connect(function(input, gpe)
		if not gpe and input.KeyCode == self.CloseKey then
			self:ToggleUI()
		end
	end)

	-- Cursor dot
	self.cursor = self.cursor or self:Create("Frame", {
		ZIndex           = 100,
		AnchorPoint      = Vector2.new(0, 0),
		Size             = UDim2.new(0, 5, 0, 5),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		Parent           = self.fadeContainer or self.base,
	})

	-- Built-in settings panel
	if self.SettingsGui and not self._themePanelInjected then
		self._themePanelInjected = true
		self.flags.uwuware_theme        = self.currentTheme
		self.flags.uwuware_config_slot  = self.flags.uwuware_config_slot or "main"
		self.flags.uwuware_startup_style = self.defaultTheme
		self.flags.uwuware_ui_toggle_key = self.CloseKey.Name

		local settingsWin = self:CreateWindow("Settings")

		settingsWin:AddList({
			text     = "Style",
			values   = themeNames,
			value    = self.currentTheme,
			flag     = "uwuware_theme",
			callback = function(v) self:SetTheme(v) end,
		})

		settingsWin:AddButton({
			text     = "Save Style",
			flag     = "uw_style_as_default",
			callback = function() self:SetDefaultTheme(self.currentTheme) end,
		})

		settingsWin:AddBind({
			text           = "Toggle UI key",
			flag           = "uwuware_ui_toggle_key",
			key            = self.CloseKey.Name,
			applyAsCloseKey = true,
			callback       = function() end,
		})

		settingsWin:AddButton({
			text     = "Destroy Script",
			callback = function() self.base:Destroy() end,
		})

		if self.SaveSlotEnabled then
			settingsWin:AddBox({
				text     = "Slot name",
				flag     = "uwuware_config_slot",
				value    = tostring(self.flags.uwuware_config_slot),
				callback = function() end,
			})
			settingsWin:AddButton({
				text     = "Save",
				flag     = "uw_cfg_save",
				callback = function() self:SaveConfig() end,
			}):AddButton({
				text     = "Load",
				flag     = "uw_cfg_load",
				callback = function() self:LoadConfig() end,
			})
		end
	end

	local guiParent = self.fadeContainer or self.base
	for _, window in ipairs(self.windows) do
		if window.canInit and not window.init then
			window.init = true
			createOptionHolder(window.title, guiParent, window)
			loadOptions(window)
		end
	end
end

function library:Close()
	self:ToggleUI()
end

-- ── Global popup dismiss ──────────────────────────────────────────────────────
inputService.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
	if not library.activePopup then return end
	local holder = library.activePopup.mainHolder
	if not holder then return end
	local ax, ay = holder.AbsolutePosition.X, holder.AbsolutePosition.Y
	local aw, ah = holder.AbsoluteSize.X,     holder.AbsoluteSize.Y
	local px, py = input.Position.X,          input.Position.Y
	if px < ax or py < ay or px > ax + aw or py > ay + ah then
		library.activePopup:Close()
	end
end)

-- ── Cursor + drag update ──────────────────────────────────────────────────────
inputService.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement then
		if library.cursor then
			-- GetMouseLocation already returns screen-space coords; no manual offset needed.
			local mouse = inputService:GetMouseLocation()
			library.cursor.Position = UDim2.new(0, mouse.X - 2, 0, mouse.Y - 2)
		end
		if input == dragInput and dragging then
			updateDrag(input)
		end
	end
end)

return library
