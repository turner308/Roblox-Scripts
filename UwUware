-- ── GUI Protection ────────────────────────────────────────────────────────────
-- Build a safe protect_gui shim before anything else touches CoreGui.
local function _buildProtectGui()
	-- gethui() executor support (Fluxus, etc.)
	if type(gethui) == "function" then
		local hgui = pcall(gethui) and gethui()
		if hgui then
			return function(gui) gui.Parent = hgui end
		end
	end
	-- get_hidden_gui support
	if type(get_hidden_gui) == "function" then
		return function(gui) get_hidden_gui(gui) end
	end
	-- Fallback: CoreGui with pcall
	return function(gui)
		gui.Parent = game:GetService("CoreGui")
	end
end

local _protectGui = _buildProtectGui()

