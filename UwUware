		Image            = "rbxassetid://4918373417",
		ImageColor3      = parentTable.open and sh.arrowOpen or sh.arrowClosed,
		ScaleType        = Enum.ScaleType.Fit,
		Parent           = closeHolder,
	})

	parentTable.content = library:Create("Frame", {
		Position         = UDim2.new(0, 0, 0, size),
		Size             = UDim2.new(1, 0, 1, -size),
		BackgroundTransparency = 1,
		Parent           = parentTable.main,
	})

	local layout = library:Create("UIListLayout", {
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent    = parentTable.content,
	})

	layout.Changed:Connect(function()
		parentTable.content.Size = UDim2.new(1, 0, 0, layout.AbsoluteContentSize.Y)
		parentTable.main.Size = (#parentTable.options > 0 and parentTable.open)
			and UDim2.new(0, 230, 0, layout.AbsoluteContentSize.Y + size)
			or  UDim2.new(0, 230, 0, size)
	end)

	if not subHolder then
		library:Create("UIPadding", { Parent = parentTable.content })

		title.InputBegan:Connect(function(input)
			local ut = input.UserInputType
			if ut == Enum.UserInputType.MouseButton1 or ut == Enum.UserInputType.Touch then
				dragObject = parentTable.main
				dragging   = true
				dragStart  = input.Position
				startPos   = dragObject.Position
			end
		end)
		title.InputChanged:Connect(function(input)
			if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
				dragInput = input
			end
		end)
		title.InputEnded:Connect(function(input)
			local ut = input.UserInputType
			if ut == Enum.UserInputType.MouseButton1 or ut == Enum.UserInputType.Touch then
				dragging = false
			end
		end)
	end

	closeHolder.InputBegan:Connect(function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
		parentTable.open = not parentTable.open
		local s = library._sh
		local ti = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		tweenService:Create(closeArrow, ti, {
			Rotation   = parentTable.open and 90 or 180,
			ImageColor3 = parentTable.open and s.arrowOpen or s.arrowClosed,
		}):Play()
		if subHolder then
			tweenService:Create(title, ti, {
				BackgroundColor3 = parentTable.open and s.subClosed or library.Colors.Topbar,
			}):Play()
		elseif roundBg then
			tweenService:Create(roundBg, ti, {
				ImageColor3 = parentTable.open and library.Colors.Topbar or s.closedTop,
			}):Play()
		end
		parentTable.main:TweenSize(
			(#parentTable.options > 0 and parentTable.open)
				and UDim2.new(0, 230, 0, layout.AbsoluteContentSize.Y + size)
				or  UDim2.new(0, 230, 0, size),
			Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true
		)
	end)

	function parentTable:SetTitle(newTitle)
		title.Text = tostring(newTitle)
	end

	library:RegisterThemeHook(function()
		local s    = library._sh
		local open = parentTable.open
		parentTable.main.ImageColor3 = library.Colors.Background
		if roundBg then
			roundBg.ImageColor3 = open and library.Colors.Topbar or s.closedTop
		elseif subHolder then
			title.BackgroundColor3 = open and s.subClosed or library.Colors.Topbar
		end
		title.TextColor3    = library.Colors.Text
		closeArrow.ImageColor3 = open and s.arrowOpen or s.arrowClosed
	end)

	return parentTable
end

