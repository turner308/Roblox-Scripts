-- ── Toggle ────────────────────────────────────────────────────────────────────
local function createToggle(option, parent)
	local main = library:Create("TextLabel", {
		LayoutOrder        = option.position,
		Size               = UDim2.new(1, 0, 0, 31),
		BackgroundTransparency = 1,
		Text               = " " .. option.text,
		RichText           = true,
		TextSize           = 17,
		Font               = Enum.Font.Gotham,
		TextColor3         = library.Colors.Text,
		TextXAlignment     = Enum.TextXAlignment.Left,
		Parent             = parent.content,
	})

	local sh = library._sh
	local tickboxOutline = library:Create("ImageLabel", {
		Position   = UDim2.new(1, -6, 0, 4),
		Size       = UDim2.new(-1, 10, 1, -10),
		SizeConstraint = Enum.SizeConstraint.RelativeYY,
		BackgroundTransparency = 1,
		Image      = "rbxassetid://3570695787",
		ImageColor3 = option.state and library.Colors.Accent or library.Colors.Outline,
		ScaleType  = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent     = main,
	})

	local tickboxInner = library:Create("ImageLabel", {
		Position   = UDim2.new(0, 2, 0, 2),
		Size       = UDim2.new(1, -4, 1, -4),
		BackgroundTransparency = 1,
		Image      = "rbxassetid://3570695787",
		ImageColor3 = option.state and library.Colors.Accent or sh.deepBox,
		ScaleType  = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(100, 100, 100, 100),
		SliceScale = 0.02,
		Parent     = tickboxOutline,
	})

	local checkmarkHolder = library:Create("Frame", {
		Position   = UDim2.new(0, 4, 0, 4),
		Size       = option.state and UDim2.new(1, -8, 1, -8) or UDim2.new(0, 0, 1, -8),
		BackgroundTransparency = 1,
		ClipsDescendants = true,
		Parent     = tickboxOutline,
	})

	library:Create("ImageLabel", {
		Size       = UDim2.new(1, 0, 1, 0),
		SizeConstraint = Enum.SizeConstraint.RelativeYY,
		BackgroundTransparency = 1,
		Image      = "rbxassetid://4919148038",
		ImageColor3 = sh.deepBox,
		Parent     = checkmarkHolder,
	})

	local inContact = false
	local ti02 = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local ti01 = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	main.InputBegan:Connect(function(input)
		local ut = input.UserInputType
		if ut == Enum.UserInputType.MouseButton1 then
			option:SetState(not option.state)
		elseif ut == Enum.UserInputType.MouseMovement then
			inContact = true
			if not option.state then
				tweenService:Create(tickboxOutline, ti01, { ImageColor3 = library._sh.tickHoverInactive }):Play()
			end
		end
	end)

	main.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			inContact = false
			if not option.state then
				tweenService:Create(tickboxOutline, ti01, { ImageColor3 = library.Colors.Outline }):Play()
			end
		end
	end)

	function option:SetState(state)
		library.flags[self.flag] = state
		self.state = state
		local s = library._sh
		checkmarkHolder:TweenSize(
			state and UDim2.new(1, -8, 1, -8) or UDim2.new(0, 0, 1, -8),
			Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true
		)
		tweenService:Create(tickboxInner, ti02, {
			ImageColor3 = state and library.Colors.Accent or s.deepBox,
		}):Play()
		if state then
			tweenService:Create(tickboxOutline, ti02, { ImageColor3 = library.Colors.Accent }):Play()
		else
			tweenService:Create(tickboxOutline, ti02, {
				ImageColor3 = inContact and s.tickHoverInactive or library.Colors.Outline,
			}):Play()
		end
		self.callback(state)
	end

	if option.state then
		task.defer(function() option.callback(true) end)
	end

	setmetatable(option, { __newindex = function(_, i, v)
		if i == "Text" then main.Text = " " .. tostring(v) end
	end })

	function option:RefreshFromFlags()
		local v = library.flags[self.flag]
		if typeof(v) == "boolean" and self.state ~= v then self:SetState(v) end
	end

	library:RegisterThemeHook(function()
		local s = library._sh
		main.TextColor3 = library.Colors.Text
		if option.state then
			tickboxInner.ImageColor3   = library.Colors.Accent
			tickboxOutline.ImageColor3 = library.Colors.Accent
		else
			tickboxInner.ImageColor3   = s.deepBox
			tickboxOutline.ImageColor3 = inContact and s.tickHoverInactive or library.Colors.Outline
		end
	end)
end

-- ── Shared button wiring ──────────────────────────────────────────────────────
local function wireStandardButton(main, roundImg, option)
	local inContact = false
	local clicking  = false
	local ti02 = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local ti01 = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	main.InputBegan:Connect(function(input)
		local ut = input.UserInputType
		if ut == Enum.UserInputType.MouseButton1 then
			library.flags[option.flag] = true
			clicking = true
			tweenService:Create(roundImg, ti02, { ImageColor3 = library.Colors.Accent }):Play()
			option.callback()
		elseif ut == Enum.UserInputType.MouseMovement then
			inContact = true
			tweenService:Create(roundImg, ti01, { ImageColor3 = library._sh.surfaceHi }):Play()
		end
	end)

	main.InputEnded:Connect(function(input)
		local ut = input.UserInputType
		if ut == Enum.UserInputType.MouseButton1 then
			clicking = false
			tweenService:Create(roundImg, ti02, {
				ImageColor3 = inContact and library._sh.surfaceHi or library._sh.surface,
			}):Play()
		elseif ut == Enum.UserInputType.MouseMovement then
			inContact = false
			if not clicking then
				tweenService:Create(roundImg, ti01, { ImageColor3 = library._sh.surface }):Play()
			end
		end
	end)

	library:RegisterThemeHook(function()
		main.TextColor3    = library.Colors.Text
		local s            = library._sh
		roundImg.ImageColor3 = (inContact or clicking) and s.surfaceHi or s.surface
	end)
end

