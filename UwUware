function library:SetTheme(name)
	if not Themes[name] then return end
	self.currentTheme = name
	for k, v in pairs(Themes[name]) do
		self.Colors[k] = v
	end
	self:RefreshShades()
	for _, fn in ipairs(self._themeHooks) do
		pcall(fn)
	end
	if self.flags then
		self.flags.uwuware_theme = name
	end
end

